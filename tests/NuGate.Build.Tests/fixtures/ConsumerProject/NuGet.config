<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Restore NuGate.Build from the repo-local feed (../../../../artifacts) plus nuget.org for the
    rest. clear drops any inherited machine feeds so the fixture is deterministic.
  -->
  <packageSources>
    <clear />
    <add key="nugate-local" value="..\..\..\..\artifacts" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
